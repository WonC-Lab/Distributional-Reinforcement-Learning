# ==============================================================================
# Git Ignore Configuration
# Author: WonChan Cho
# Date: July 08, 2026
# Description: Prevents uploading LaTeX paper drafts, CSV data, and plots.
# ==============================================================================

# LaTeX files (paper draft kept private)
*.tex
*.aux
*.log
*.out
*.toc
*.synctex.gz
*.pdf

# Python bytecode
__pycache__/
*.pyc

# Large market data cache and raw result CSVs
market_ez_cache_*.csv
dist_rl_ez_experiment_returns.csv
dist_rl_ez_consumption.csv
dist_rl_ez_rep_weights.csv

# Allow summary CSVs (small, useful for readers)
!dist_rl_ez_summary_stats.csv
!dist_rl_ez_extended_metrics.csv
!dist_rl_ez_within_model_tests.csv

# Exclude all figures by default
figure_ez_*.png

# Allow key paper figures for README display
!figure_ez_portfolio_growth.png
!figure_ez_asset_allocation.png
!figure_ez_consumption_rate.png
!figure_ez_ablation.png
!figure_ez_sharpe_comparison.png
!figure_ez_cer_comparison.png
!figure_ez_sortino_calmar.png

# IDE settings
.vscode/
.idea/
